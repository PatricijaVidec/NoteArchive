@{
    ViewData["Title"] = "Home Page";
}

<div class="jumbotron">
    <h1>Note Archive</h1>
</div>
<div class="row">
    <div class="col-md-4">
        <h2>Welcome to Note Archive</h2>
        <p>
            Note Archive is an application that
            archives the notes the user wants to save for personal use. 
            If in real life they lose the notes they can re-download.
        </p>
    </div>
    <div class="col-md-4">
        <h2>Build it yourself</h2>
        <p>You can build the application by following the steps in a series of tutorials and create your own version.</p>
        <p><a class="btn btn-default" href="https://docs.asp.net/en/latest/data/ef-mvc/intro.html">See the tutorial &raquo;</a></p>
    </div>
    <div class="col-md-4">
        <h2>Download it</h2>
        <p>You can download the completed project from GitHub.</p>
        <p><a class="btn btn-default" href="https://github.com/PatricijaVidec/NoteArchive">See project source code &raquo;</a></p>
    </div>
</div>