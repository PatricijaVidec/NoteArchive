@model IEnumerable<NoteArchive.Models.Note>
@using System.Security.Claims

<div class="row">
@foreach (var item in Model)
{
    <div class="col-md-3 mb-4">

        <div class="card h-100">

            @{
                var preview = item.Images?.FirstOrDefault();
            }

            @if (preview != null)
            {
                <img src="@preview.ImagePath"
                     class="card-img-top"
                     style="height:300px; object-fit:cover;" />
            }

            <div class="card-body">

                <h5>@item.Title</h5>

                <p>@item.Author</p>

                <a asp-action="Details"
                   asp-route-id="@item.ID"
                   class="btn btn-primary">
                    Open
                </a>

                @if (
                    User.IsInRole("Administrator")
                    || User.FindFirstValue(ClaimTypes.NameIdentifier) == item.UserID
                )
                {
                    <a asp-action="Delete"
                       asp-route-id="@item.ID"
                       class="btn btn-danger">
                        Delete
                    </a>
                }

            </div>
        </div>
    </div>
}
</div>